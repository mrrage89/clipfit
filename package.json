{
  "name": "clipfit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ext": "vite build --mode extension && node scripts/build-ext.mjs",
